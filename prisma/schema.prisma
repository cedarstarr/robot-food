generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  password      String?
  name          String?
  image         String?
  isAdmin       Boolean   @default(false) @map("is_admin")

  unsubscribeToken    String?   @unique @map("unsubscribe_token")
  emailUnsubscribedAt DateTime? @map("email_unsubscribed_at")
  notifyMarketing     Boolean   @default(true) @map("notify_marketing")
  notifyProduct       Boolean   @default(true) @map("notify_product")

  pendingEmail      String?   @map("pending_email")
  emailChangeToken  String?   @unique @map("email_change_token")
  emailChangeExpiry DateTime? @map("email_change_expiry")

  sessionsRevokedAt DateTime? @map("sessions_revoked_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accounts Account[]
  sessions Session[]
  recipes  Recipe[]

  @@index([email])
  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("password_reset_tokens")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  action    String
  ip        String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Recipe {
  id          String  @id @default(cuid())
  userId      String  @map("user_id")
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String? @db.Text
  servings    Int     @default(4)
  prepTimeMin Int?    @map("prep_time_min")
  cookTimeMin Int?    @map("cook_time_min")
  cuisine     String?
  difficulty  String?

  sourceIngredients String[] @map("source_ingredients")
  recipeData        Json     @map("recipe_data")
  rawText           String   @db.Text @map("raw_text")
  nutrition         Json?
  fromPhoto         Boolean  @default(false) @map("from_photo")
  modifications     Json     @default("[]")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("recipes")
}

model JobRun {
  id         String    @id @default(cuid())
  job        String
  trigger    String    @default("cron")
  startedAt  DateTime  @default(now()) @map("started_at")
  finishedAt DateTime? @map("finished_at")
  durationMs Int?      @map("duration_ms")
  success    Boolean?
  result     Json?
  error      String?   @db.Text

  @@index([job, startedAt(sort: Desc)])
  @@map("job_runs")
}
